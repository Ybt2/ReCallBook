# ReCallBook Configuration
# Copy this file to .env and adjust values.

# ─── Required ──────────────────────────────────────────
# Secret key for JWT token signing. CHANGE THIS.
JWT_SECRET=change-me-to-a-random-string

# ─── Database ──────────────────────────────────────────
DB_PASSWORD=recallbook
DB_NAME=recallbook

# ─── Ports (change if ports conflict on your machine) ──
MYSQL_PORT=3306
QDRANT_PORT=6333
OLLAMA_PORT=11434
BACKEND_PORT=3000
FRONTEND_PORT=9090

# ─── Ollama Models ─────────────────────────────────────
# Comma-separated list of models to auto-download.
# bge-m3 is required for embeddings. At least one chat model is needed.
OLLAMA_MODELS=bge-m3,llama3.2

# ─── CORS ──────────────────────────────────────────────
# Origins allowed to access the backend API.
CORS_ORIGINS=http://localhost:9090

# ═══════════════════════════════════════════════════════════
# ⚠️  ADVANCED CONFIGURATION
# Only change these if you are sure of what you are doing.
# The defaults work for most users.
# ═══════════════════════════════════════════════════════════

# Override the embedding model (default: bge-m3)
# OLLAMA_EMBEDDING_MODEL=bge-m3

# JWT token expiry duration (default: 7d)
# JWT_EXPIRES_IN=7d

# MySQL connection (defaults: localhost / root)
# DB_HOST=localhost
# DB_USER=root

# Set to "production" for stricter CORS (requires Origin header).
# NODE_ENV=production
